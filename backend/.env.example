# ========================
# MindMate Backend — Environment Variables
# Copy this file to .env and fill in your values
# ========================

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/mindmate?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Redis (Upstash free tier or local)
REDIS_URL=redis://localhost:6379
# Upstash: rediss://:<password>@<host>:<port>

# ---- AI: Google Gemini ----
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...your-gemini-api-key...
GEMINI_MODEL=gemini-2.0-flash

# ---- Voice: ElevenLabs (Free Plan) ----
# Get your key at: https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Free plan voices (pick one):
#   Rachel  → 21m00Tcm4TlvDq8ikWAM  (default, calm female)
#   Domi    → AZnzlk1XvdvUeBnXmlld  (confident female)
#   Bella   → EXAVITQu4vr4xnSDxMaL  (soft female)
#   Josh    → TxGEqnHWrfWFTfGW9XjX  (young male)
#   Adam    → pNInz6obpgDQGcFmaJgB  (deep male)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# eleven_monolingual_v1 = free plan model (do NOT change unless on paid plan)
ELEVENLABS_MODEL_ID=eleven_monolingual_v1

# Rate Limiting
MAX_SESSIONS_PER_DAY=20

# Session Config
SESSION_TTL_SECONDS=1800
ANALYTICS_CACHE_TTL_SECONDS=3600
REPORT_CACHE_TTL_SECONDS=900
MAX_QUESTIONS_PER_SESSION=5

# CORS
FRONTEND_URL=http://localhost:5173
